{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/amjiddader/ustore/main/schema.json",
  "title": "uStore Package Registry",
  "description": "Schema for the uStore source.json package registry file",
  "type": "object",
  "required": ["schema_version", "repository", "categories", "packages"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference URL"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the registry schema"
    },
    "repository": {
      "type": "object",
      "required": ["name", "maintainer", "url", "license", "last_updated", "total_packages"],
      "properties": {
        "name": { "type": "string" },
        "maintainer": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "license": { "type": "string" },
        "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "total_packages": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "icon", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "name": { "type": "string" },
          "icon": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "name", "description", "category", "icon", "website",
          "publisher", "license", "tags", "verified", "added_date",
          "updated_date", "popularity", "variants", "dependencies",
          "post_install", "pre_remove", "auto_update"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Unique package identifier (lowercase, hyphens allowed)"
          },
          "name": { "type": "string", "description": "Display name of the application" },
          "description": { "type": "string", "description": "Short description of the application" },
          "category": { "type": "string", "description": "Category ID this package belongs to" },
          "icon": { "type": "string", "description": "URL to the application icon" },
          "website": { "type": "string", "format": "uri", "description": "Official website URL" },
          "publisher": { "type": "string", "description": "Publisher or developer name" },
          "license": { "type": "string", "description": "License identifier (e.g. mit, gpl-3.0, proprietary)" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Search tags for the package"
          },
          "alt_names": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Alternative names/aliases for search (e.g. short names, common misspellings)"
          },
          "verified": { "type": "boolean", "description": "Whether the package is verified/curated" },
          "added_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "updated_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "popularity": { "type": "integer", "minimum": 1, "maximum": 5 },
          "variants": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["version", "arch", "type", "url", "size_mb"],
              "properties": {
                "version": { "type": "string", "description": "Package version (real version, not 'latest')" },
                "arch": {
                  "type": "string",
                  "enum": ["amd64", "arm64", "armhf", "i386", "all"],
                  "description": "Target architecture"
                },
                "type": {
                  "type": "string",
                  "enum": ["deb", "tar.gz", "tar.xz", "binary", "appimage", "run"],
                  "description": "Package format type"
                },
                "url": { "type": "string", "format": "uri", "description": "Download URL" },
                "sha256": { "type": "string", "description": "SHA256 checksum (empty string if not available)" },
                "size_mb": { "type": "integer", "minimum": 1, "description": "Approximate size in MB" },
                "min_ubuntu": { "type": "string", "pattern": "^\\d+\\.\\d+$", "description": "Minimum Ubuntu version required" }
              },
              "additionalProperties": false
            }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "System package dependencies"
          },
          "dpkg_name": { "type": "string", "description": "dpkg package name (for .deb packages)" },
          "binary_name": { "type": "string", "description": "Executable binary name" },
          "desktop_entry": { "type": "string", "description": ".desktop file name" },
          "install_args": { "type": "string", "description": "Arguments to pass to .run installer (e.g. '-i' for silent install)" },
          "post_script": { "type": "string", "format": "uri", "description": "URL to a post-install bash script to run after installation" },
          "post_install": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Commands to run after installation"
          },
          "pre_remove": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Commands to run before removal"
          },
          "auto_update": { "type": "boolean", "description": "Whether the app handles its own updates" },
          "notes": { "type": "string", "description": "Additional notes about the package" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
